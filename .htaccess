<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /recruitment/

  # Let PHP files load normally
  RewriteRule \.php$ - [L]

  # Let API requests load normally
  RewriteRule ^api/ - [L]

  # For any requests inside /recruitment/ that ARE NOT files (-f) or directories (-d)...
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # ...route them to build/index.html (This handles SPA logic like /admin, /apply)
  RewriteRule ^(.*)$ build/index.html [L]

  # This is the kicker: If they ask for /recruitment/ DIRECTLY (which IS a directory, so the condition above failed)
  # BUT it has no normal index file inside it, route them manually to build/index.html
  RewriteRule ^$ build/index.html [L]
</IfModule>
