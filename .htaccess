<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /recruitment/

  # Allow API requests to pass through to the api folder
  RewriteCond %{REQUEST_URI} ^/recruitment/api/ [NC]
  RewriteRule ^ - [L]

  # Serve files directly from the build folder if they exist
  RewriteCond %{DOCUMENT_ROOT}/recruitment/build%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/recruitment/build%{REQUEST_URI} -d
  RewriteRule ^(.*)$ build/$1 [L]

  # Otherwise, fall back to the SPA entry point
  RewriteRule ^ build/index.html [L]
</IfModule>
