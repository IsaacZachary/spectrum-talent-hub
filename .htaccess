<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /recruitment/

  # Pass PHP files directly (deploy.php, api scripts)
  RewriteRule \.php$ - [L]

  # Pass api folder directly
  RewriteRule ^api/ - [L]

  # Route assets and static files to build/ subfolder
  RewriteRule ^assets/(.+)$ build/assets/$1 [L]
  RewriteRule ^(logo\.png|favicon\.ico|robots\.txt|placeholder\.svg)$ build/$1 [L]

  # Route EVERYTHING ELSE to build/index.html (no !-d condition)
  RewriteRule ^ build/index.html [L]
</IfModule>
